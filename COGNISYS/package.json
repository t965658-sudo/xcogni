{
  "name": "cognisysai",
  "version": "2.0.0",
  "description": "CognisysAI - Enterprise AI Chatbot Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch --coverage",
    "test:e2e": "jest --config jest.e2e.config.js --forceExit",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "migrate": "node src/database/migrate.js",
    "migrate:seed": "node src/database/seed.js",
    "docker:build": "docker build -t cognisysai .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "ci": "npm run lint && npm test"
  },
  "keywords": ["ai", "chatbot", "saas", "enterprise"],
  "author": "Faik Mulla",
  "license": "MIT",
  "type": "commonjs",
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "express": "^4.21.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "csurf": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "uuid": "^10.0.0",
    "pg": "^8.13.1",
    "pg-pool": "^2.0.10",
    "ioredis": "^5.4.1",
    "winston": "^3.15.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "marked": "^14.1.3",
    "highlight.js": "^11.10.0",
    "sanitize-html": "^2.13.1",
    "socket.io": "^4.8.1",
    "@sentry/node": "^8.47.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "nodemon": "^3.1.7",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0"
  }
}